# Template for conf/local/credentials.yml.
# Copy this to credentials.yml (in the same folder) and fill in real values.
# The real credentials.yml is gitignored. This .yml.example file is committed
# and named with a non-YAML extension so Kedro's config loader skips it.

openai:
  api_key: <your-openai-api-key>
  # base_url: optional, only if using a non-default endpoint

langfuse_credentials:
  public_key: <your-langfuse-public-key>
  secret_key: <your-langfuse-secret-key>
  host: https://cloud.langfuse.com
