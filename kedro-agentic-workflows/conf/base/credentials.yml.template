# Credentials template. Copy this to `conf/base/credentials.yml` (gitignored)
# and fill in real values. `conf/**/*credentials*` in .gitignore keeps secrets
# out of git.
#
# Note: `default_run_env = "langfuse"` means a plain `kedro run` loads
# conf/base/ + conf/langfuse/ only. `conf/local/` is NOT layered on top, and
# Kedro's `--env` flag takes a single env name (no comma-stacking), so
# credentials must live in `conf/base/credentials.yml` for the default setup
# to work.

# --- OpenAI ---
openai:
  base_url: "https://api.openai.com/v1"
  api_key: "<openai-api-key>"

# --- Database ---
db_credentials:
  # SQLAlchemy connection string, e.g.
  #   sqlite:///demo-db.sqlite
  #   postgresql+psycopg2://user:pass@host:port/dbname
  con: "sqlite:///demo-db.sqlite"

# --- Langfuse (used when --env langfuse) ---
# `endpoint` is only required for autogen mode (OTLP exporter).
langfuse_credentials:
  public_key: "<langfuse-public-key>"
  secret_key: "<langfuse-secret-key>"
  # host: "https://cloud.langfuse.com"   # optional; defaults to Langfuse cloud
  endpoint: "https://cloud.langfuse.com/api/public/otel/v1/traces"

# --- Opik (used when --env opik) ---
# The autogen block reuses opik_credentials via a YAML anchor (`<<: *opik_creds`)
# so the shared keys live in one place; only `endpoint` diverges.
opik_credentials: &opik_creds
  api_key: "<opik-api-key>"
  workspace: "<opik-workspace>"
  project_name: "<opik-project-name>"

# TEMP workaround block for an upstream bug.
# opik.PromptDataset and opik.EvaluationDataset (kedro-datasets 9.4.0) splat
# the whole credentials dict into Opik(**credentials), which doesn't accept
# `endpoint`. Keeping the OTLP endpoint isolated here lets the autogen tracer
# work without breaking the other Opik datasets that share opik_credentials.
# Upstream fix: https://github.com/kedro-org/kedro-plugins/pull/1416
# Once that merges and ships in a kedro-datasets release > 9.4.0:
#   1. move `endpoint` into the opik_credentials block above
#   2. delete this opik_credentials_autogen block
#   3. point conf/opik/catalog_genai_config.yml's autogen_tracer back to opik_credentials
opik_credentials_autogen:
  <<: *opik_creds
  endpoint: "https://www.comet.com/opik/api/v1/private/otel/v1/traces"
